<project>
	<modelVersion>4.0.0</modelVersion>
	<groupId>be.nabu</groupId>
	<artifactId>modules</artifactId>
	<version>1.0-SNAPSHOT</version>
	<packaging>pom</packaging>
	
	<dependencies>
		<dependency>
			<groupId>junit</groupId>
			<artifactId>junit</artifactId>
			<version>4.11</version>
			<scope>test</scope>
		</dependency>
	</dependencies>
	
	<dependencyManagement>
		<dependencies>
			<dependency>
				<groupId>be.nabu</groupId>
				<artifactId>modules-bom</artifactId>
				<version>1.0-SNAPSHOT</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
		</dependencies>
	</dependencyManagement>


	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jarsigner-plugin</artifactId>
				<version>1.4</version>
				<executions>
					<execution>
						<id>sign</id>
						<goals>
							<goal>sign</goal>
							<goal>verify</goal>
						</goals>
					</execution>
				</executions>
				<configuration>
					<keystore>${sign.keystore}</keystore>
					<alias>${sign.alias}</alias>
					<storepass>${sign.storepass}</storepass>
					<keypass>${sign.keypass}</keypass>
					<tsa>${sign.tsa}</tsa>
				</configuration>
			</plugin>
			<!-- needed to get build time -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jar-plugin</artifactId>
				<configuration>
					<archive>
						<manifestEntries>
							<Build-Time>${maven.build.timestamp}</Build-Time>
							<Build-Version>${project.version}</Build-Version>
						</manifestEntries>
					</archive>
				</configuration>
			</plugin>
		</plugins>
		<resources>
			<resource>
				<directory>.</directory>
				<excludes>
					<exclude>.flattened-pom.xml</exclude>
					<exclude>target</exclude>
					<exclude>pom.xml</exclude>
					<exclude>.pom.xml.swp</exclude>
					<exclude>.gitignore</exclude>
					<exclude>.github</exclude>
					<exclude>.github/**</exclude>
					<exclude>.tmp</exclude>
					<exclude>.tmp/**</exclude>
					<exclude>.git</exclude>
					<exclude>RELEASE.md</exclude>
					<exclude>LICENSE</exclude>
					<exclude>LICENSE.GPL</exclude>
				</excludes>
			</resource>
		</resources>
		<finalName>${project.groupId}.${project.artifactId}.${project.version}</finalName>
		<directory>/tmp/${project.groupId}.${project.artifactId}</directory>
	</build>
</project>
